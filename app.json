{
  "expo": {
    "name": "Bingket",
    "slug": "bingkit",
    "version": "1.0.0",
    "scheme": "bingket",
    "orientation": "portrait",
    "icon": "./assets/logo_300.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.day.bingket"
    },
    "android": {
      "package": "com.day.bingket",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진 설정 및 게시글 이미지 첨부를 위해 사진 라이브러리 접근 권한이 필요해요.",
          "cameraPermission": "프로필 사진 촬영 및 게시글 이미지 첨부를 위해 카메라 접근 권한이 필요해요."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-dynamic-app-icon",
        {
          "default": {
            "image": "./assets/icon_themes/icon_theme_default.png",
            "prerendered": true
          },
          "neon": {
            "image": "./assets/icon_themes/icon_theme_neon.png",
            "prerendered": true
          },
          "sunset": {
            "image": "./assets/icon_themes/icon_theme_sunset.png",
            "prerendered": true
          },
          "tanning": {
            "image": "./assets/icon_themes/icon_theme_tanning.png",
            "prerendered": true
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo_300.png",
          "color": "#F07840",
          "iosDisplayInForeground": true
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "81a85ba8-51d4-4399-9406-42c2ea33fc25"
      }
    },
    "owner": "dybang"
  }
}
